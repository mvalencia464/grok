---
import '../styles/global.css';
import iconSvg from '../assets/icon.svg';

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
const site = (await import('../data/site.json')).default;
const fullTitle = `${title} | ${site.businessName}`;
const metaDescription = description ?? `${site.tagline} Custom decks, repairs & outdoor living in ${site.primaryCity}. Free estimates.`;
const canonicalUrl = new URL(Astro.url.pathname, Astro.url.origin).href;
const logoParts = site.businessName.split(' ').filter((p: string) => p !== 'AK');
const logoFirst = logoParts[0] ?? '';
const logoRest = logoParts.slice(1).join('');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>{fullTitle}</title>
    <meta name="description" content={metaDescription} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:url" content={canonicalUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={metaDescription} />
    <link rel="icon" type="image/svg+xml" href={typeof iconSvg === 'string' ? iconSvg : iconSvg.src} sizes="any" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Oswald:wght@500;600;700&display=swap"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Oswald:wght@500;600;700&display=swap"
      />
    </noscript>
    </head>
  <body>
    <header class="sticky top-0 z-50 w-full bg-white border-b border-neutral-200/80">
      <nav class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 relative" aria-label="Main">
        <input type="checkbox" id="menu-toggle" class="peer sr-only" aria-hidden="true" />
        <!-- Full-screen menu canvas (mobile) -->
        <div class="fixed inset-0 z-40 bg-white transform translate-x-full transition-transform duration-300 ease-out peer-checked:translate-x-0 md:translate-x-0 md:static md:hidden md:pointer-events-none" aria-hidden="true">
          <div class="flex flex-col min-h-full pt-24 pb-8 px-6">
            <label for="menu-toggle" class="absolute top-6 right-4 p-2 -m-2 cursor-pointer text-neutral-600 hover:text-brand-orange rounded-sm focus-ring" aria-label="Close menu">
              <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
            </label>
            <ul class="flex flex-col gap-0 text-center" role="list">
              <li><a href="/" class="block py-4 text-lg font-medium text-neutral-800 hover:text-brand-orange border-b border-neutral-100">Home</a></li>
              <li><a href="/services" class="block py-4 text-lg font-medium text-neutral-800 hover:text-brand-orange border-b border-neutral-100">Services</a></li>
              <li><a href="/#reviews" class="block py-4 text-lg font-medium text-neutral-800 hover:text-brand-orange border-b border-neutral-100">Reviews</a></li>
              <li><a href="/about" class="block py-4 text-lg font-medium text-neutral-800 hover:text-brand-orange border-b border-neutral-100">About</a></li>
              <li><a href="/contact" class="block py-4 text-lg font-medium text-neutral-800 hover:text-brand-orange border-b border-neutral-100">Contact</a></li>
            </ul>
            <a href="/#quote" class="mt-8 mx-auto w-full max-w-xs bg-brand-orange hover:bg-orange-800 text-white px-6 py-4 font-bold text-sm uppercase tracking-wider text-center transition-colors focus-ring rounded-none">
              Get Quote →
            </a>
          </div>
        </div>
        <!-- Top bar -->
        <div class="flex items-center justify-between h-20">
          <!-- Mobile: hamburger (left) | logo (center) | phone (right) -->
          <div class="md:hidden grid grid-cols-[auto_1fr_auto] items-center w-full gap-2">
            <label for="menu-toggle" class="flex justify-start p-2 -m-2 cursor-pointer text-neutral-600 hover:text-brand-orange rounded-sm focus-ring items-center min-h-[44px] min-w-[44px]" aria-label="Open menu">
              <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" /></svg>
            </label>
            <a href="/" class="flex items-center justify-center gap-1.5 transition-opacity duration-200 hover:opacity-90 focus-ring rounded-sm shrink-0 min-w-0 justify-self-center">
              <img src={typeof iconSvg === 'string' ? iconSvg : iconSvg.src} alt="DeckMasters" width="36" height="32" class="h-8 w-auto shrink-0" fetchpriority="high" />
              <span class="font-display text-2xl font-bold text-neutral-800 uppercase tracking-tight pr-px overflow-visible">{logoFirst}<span class="brand-text-gradient">{logoRest}</span></span>
            </a>
            <a href={`tel:${site.primaryPhone.replace(/\D/g, '')}`} class="flex items-center justify-center min-h-[44px] min-w-[44px] rounded-full bg-brand-orange text-white hover:bg-orange-800 shadow-md focus-ring transition-colors justify-self-end" aria-label={`Call ${site.primaryPhone}`}>
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
            </a>
          </div>
          <!-- Desktop: logo (left) -->
          <a href="/" class="hidden md:flex items-center gap-2 sm:gap-2.5 transition-opacity duration-200 hover:opacity-90 focus-ring rounded-sm overflow-visible shrink-0 min-w-0">
            <img src={typeof iconSvg === 'string' ? iconSvg : iconSvg.src} alt="DeckMasters" width="36" height="32" class="h-8 w-auto shrink-0" fetchpriority="high" />
            <span class="font-display text-3xl font-bold text-neutral-800 uppercase tracking-tight pr-px overflow-visible">{logoFirst}<span class="brand-text-gradient">{logoRest}</span></span>
          </a>
          <div class="hidden md:flex items-center gap-8 font-medium text-xs uppercase tracking-[0.2em] text-neutral-600">
            <a href="/" class="hover:text-brand-orange transition-colors duration-200">Home</a>
            <a href="/services" class="hover:text-brand-orange transition-colors duration-200">Services</a>
            <a href="/#reviews" class="hover:text-brand-orange transition-colors duration-200">Reviews</a>
            <a href="/about" class="hover:text-brand-orange transition-colors duration-200">About</a>
            <a href="/contact" class="hover:text-brand-orange transition-colors duration-200">Contact</a>
          </div>
          <div class="hidden md:flex items-center gap-4 sm:gap-6">
            <div class="hidden lg:flex flex-col items-end">
              <span class="text-[10px] uppercase text-neutral-400 font-bold">Call us</span>
              <a href={`tel:${site.primaryPhone.replace(/\D/g, '')}`} class="text-sm font-bold text-brand-dark hover:text-brand-orange transition-colors">{site.primaryPhone}</a>
            </div>
            <a href="/#quote" class="hidden md:inline-flex shrink-0 bg-brand-orange hover:bg-orange-800 text-white px-5 py-3 font-bold text-sm uppercase tracking-wider transition-all shadow-md focus-ring rounded-none">
              Get Quote →
            </a>
          </div>
        </div>
      </nav>
    </header>
    <main class="pb-20 md:pb-0">
      <slot />
    </main>
    <a
      href="/#quote"
      class="fixed left-0 right-0 z-40 md:hidden flex items-center justify-center gap-2 bg-brand-orange text-white font-bold text-sm py-3 rounded-none shadow-lg hover:bg-orange-800 active:scale-[0.98] transition-all focus-ring min-h-[52px] bottom-0 [padding-bottom:max(0.75rem,env(safe-area-inset-bottom))] [padding-left:max(1rem,env(safe-area-inset-left))] [padding-right:max(1rem,env(safe-area-inset-right))]"
      aria-label="Get quote"
    >
      Get Quote →
    </a>
    <footer class="bg-neutral-100 border-t border-neutral-200">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-16">
        <div class="grid gap-12 md:grid-cols-2 lg:grid-cols-4">
          <div>
            <p class="font-semibold text-neutral-800">{site.businessName}</p>
            {site.tagline && <p class="mt-2 text-sm text-neutral-600">{site.tagline}</p>}
          </div>
          <div>
            <p class="font-medium text-neutral-800">Hours</p>
            <p class="mt-2 text-sm text-neutral-600">{site.operatingHours || 'Contact for availability'}</p>
          </div>
          <div>
            <p class="font-medium text-neutral-800">Address</p>
            <p class="mt-2 text-sm text-neutral-600">{site.address}</p>
          </div>
          <div>
            <p class="font-medium text-neutral-800">Connect</p>
            <div class="mt-3 flex flex-wrap gap-4" aria-label="Social media">
              {site.socials.instagram && (
                <a href={site.socials.instagram} target="_blank" rel="noopener noreferrer" class="text-neutral-500 hover:text-brand-orange transition-colors duration-200 p-1 -m-1 rounded focus-ring" aria-label="Instagram">
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
                </a>
              )}
              {site.socials.facebook && (
                <a href={site.socials.facebook} target="_blank" rel="noopener noreferrer" class="text-neutral-500 hover:text-brand-orange transition-colors duration-200 p-1 -m-1 rounded focus-ring" aria-label="Facebook">
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                </a>
              )}
              {site.socials.linkedin && (
                <a href={site.socials.linkedin} target="_blank" rel="noopener noreferrer" class="text-neutral-500 hover:text-brand-orange transition-colors duration-200 p-1 -m-1 rounded focus-ring" aria-label="LinkedIn">
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                </a>
              )}
            </div>
          </div>
        </div>
        <div class="mt-12 pt-8 border-t border-neutral-200 flex flex-wrap items-center justify-between gap-4">
          <p class="text-sm text-neutral-500">© {new Date().getFullYear()} {site.businessName}. All rights reserved.</p>
          <div class="flex flex-wrap gap-6 text-sm text-neutral-500">
            <span>Free estimates</span>
            <span>Climate-durable builds</span>
            <span>Satisfaction guarantee</span>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>

---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const site = (await import('../../data/site.json')).default;
const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const title = `Blog | Deck Tips & Outdoor Living — ${site.businessName}`;
const description = `Tips on deck building, materials, and outdoor living in Alaska. From ${site.businessName}, Anchorage's deck builder.`;

/** Resolve featured image URL from post image slug (uses /projects/*.avif). */
function getPostImageUrl(slug: string | undefined): string | undefined {
  if (!slug) return undefined;
  return `/projects/${slug}.avif`;
}
---

<Layout title={title} description={description}>
  <section class="py-12 sm:py-16 lg:py-24 bg-surface border-t border-neutral-200">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-10">
        <p class="text-xs font-bold uppercase tracking-[0.2em] text-brand-orange mb-2">Blog</p>
        <h1 class="font-display text-4xl md:text-5xl font-bold text-neutral-800 uppercase tracking-tight">
          Deck Tips &amp; Ideas.
        </h1>
        <p class="mt-3 text-neutral-600 max-w-xl">
          Deck building, materials, and outdoor living ideas for {site.primaryCity} homeowners.
        </p>
      </div>
      <ul class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3" role="list">
        {posts.map((post) => {
          const imageUrl = getPostImageUrl(post.data.image);
          return (
            <li>
              <a href={`/${post.id}`} class="group block rounded-none border border-neutral-200 bg-surface-elevated overflow-hidden shadow-sm transition-shadow duration-200 hover:shadow-md focus-ring">
                {imageUrl ? (
                  <div class="aspect-[4/3] overflow-hidden bg-neutral-100">
                    <img
                      src={imageUrl}
                      alt=""
                      width={400}
                      height={300}
                      class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-[1.02]"
                      loading="lazy"
                      decoding="async"
                    />
                  </div>
                ) : (
                  <div class="aspect-[4/3] bg-neutral-100 flex items-center justify-center border-b border-neutral-100" aria-hidden="true">
                    <span class="text-3xl text-brand-orange/40">◆</span>
                  </div>
                )}
                <div class="p-5 border-t border-neutral-100">
                  <p class="text-xs font-semibold uppercase tracking-wider text-neutral-500">
                    {post.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                  </p>
                  <h2 class="mt-2 text-lg font-semibold text-neutral-800 group-hover:text-brand-orange transition-colors duration-200 line-clamp-1">
                    {post.data.title}
                  </h2>
                  <p class="mt-2 text-sm text-neutral-600 line-clamp-2">
                    {post.data.description}
                  </p>
                  <span class="mt-3 inline-block text-brand-orange font-bold text-xs uppercase tracking-wider group-hover:underline">
                    Read more →
                  </span>
                </div>
              </a>
            </li>
          );
        })}
      </ul>
    </div>
  </section>
  <section class="py-20 bg-surface-muted border-t border-neutral-200">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-neutral-600">Ready to start your project?</p>
      <a
        href="/contact#quote"
        class="mt-4 inline-flex rounded-none bg-brand-orange px-6 py-3 text-base font-medium text-white transition-colors duration-200 hover:bg-orange-800 focus-ring"
      >
        Get a free quote
      </a>
    </div>
  </section>
</Layout>

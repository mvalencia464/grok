---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import TrustBar from '../components/TrustBar.astro';
import ServiceCard from '../components/ServiceCard.astro';
import Gallery from '../components/Gallery.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import FeaturedProject from '../components/FeaturedProject.astro';
import ReviewsExperimental from '../components/ReviewsExperimental.astro';

const site = (await import('../data/site.json')).default;
const { serviceImages } = await import('../data/serviceImages.ts');
const reviewsData = (await import('../data/reviews.json')).default;
const rawReviews = reviewsData.rawReviews ?? [];
const videoReview = rawReviews.find((r: { videoUrl?: string; videoThumbnailUrl?: string }) => r.videoUrl || r.videoThumbnailUrl) ?? null;
const josephLeman = rawReviews.find((r: { author: string }) => r.author === 'Joseph Leman') ?? null;

const primaryCategory = site.categories.find((c: { isPrimary: boolean }) => c.isPrimary);
const featuredServices = primaryCategory
  ? primaryCategory.services
      .filter((s: { selected: boolean }) => s.selected)
      .slice(0, 6)
      .map((s: { name: string }) => s.name)
  : [];
const title = `Custom Decks & Repairs in ${site.primaryCity}`;
const description = `${site.tagline} ${site.businessName} — decks, outdoor living, repairs. Free estimates.`;
---

<Layout title={title} description={description}>
  <Hero />
  <TrustBar />
  <section class="py-12 sm:py-16 lg:py-24 bg-surface border-t border-neutral-200" aria-label="Services">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-10">
        <p class="text-xs font-bold uppercase tracking-[0.2em] text-brand-orange mb-2">Services</p>
        <h2 class="font-display text-4xl md:text-5xl font-bold text-neutral-800 uppercase tracking-tight">What We Build.</h2>
        <p class="mt-3 text-neutral-600 max-w-xl">
          From custom decks to repairs and general contracting — built for {site.primaryCity}'s climate.
        </p>
      </div>
      <ul class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3" role="list">
        {featuredServices.map((name) => (
          <li>
            <ServiceCard title={name} href="/services" imageUrl={serviceImages[name]} />
          </li>
        ))}
      </ul>
      <p class="mt-10">
        <a href="/services" class="text-brand-orange font-bold hover:underline uppercase text-xs tracking-wider">
          View all services →
        </a>
      </p>
    </div>
  </section>
  <Gallery />
  <ProcessSteps />
  <FeaturedProject videoReview={videoReview} josephReview={josephLeman} />
  <ReviewsExperimental />
  <section class="py-20 lg:py-28 bg-surface">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-semibold text-neutral-800 text-center">About Us</h2>
      <p class="mt-6 text-neutral-600 max-w-2xl mx-auto text-center leading-relaxed">
        {site.aboutUs}
      </p>
      <p class="mt-8 text-center">
        <a href="/about" class="text-brand-orange font-bold hover:underline uppercase text-xs tracking-wider transition-colors duration-200">
          Learn more →
        </a>
      </p>
    </div>
  </section>
</Layout>

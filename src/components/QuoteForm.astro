---
/**
 * Quote form — submits to /api/submit-quote (GHL). High-level service options only.
 */

const serviceOptions = [
  'Custom Deck Design',
  'New Deck Construction',
  'Deck Replacement',
  'Multi-level Decks',
  'Composite Decking',
  'Deck Repair & Railing',
];
const inputClass =
  'w-full border-2 border-neutral-700 bg-neutral-900/80 p-3 text-sm font-medium text-neutral-100 placeholder-neutral-500 focus:border-brand-orange focus:ring-0 outline-none rounded-none';
---

<form
  id="quote-form"
  class="space-y-4 rounded-none text-neutral-100"
  aria-label="Request a quote"
>
  <h2 class="font-display text-3xl font-bold uppercase mb-1 text-center text-neutral-50">Request Estimate</h2>
  <p class="text-center text-[10px] font-bold tracking-widest text-neutral-400 mb-8 border-b border-neutral-700 pb-4">
    THE NO-SURPRISE GUARANTEE
  </p>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <label class="block">
      <span class="sr-only">Full Name</span>
      <input type="text" name="name" required autocomplete="name" class={inputClass} placeholder="Full Name*" />
    </label>
    <label class="block">
      <span class="sr-only">Phone Number</span>
      <input type="tel" name="phone" required autocomplete="tel" class={inputClass} placeholder="Phone Number*" />
    </label>
  </div>

  <label class="block">
    <span class="sr-only">Email</span>
    <input type="email" name="email" required autocomplete="email" class={inputClass} placeholder="Email Address*" />
  </label>

  <label class="block">
    <span class="sr-only">Service type</span>
    <select name="serviceType" required class={inputClass}>
      <option value="">Select a service *</option>
      {serviceOptions.map((name) => (
        <option value={name}>{name}</option>
      ))}
    </select>
  </label>

  <label class="block">
    <span class="sr-only">Project description</span>
    <textarea name="projectDescription" rows={4} required class={inputClass} placeholder="Project description *"></textarea>
  </label>

  <button
    type="submit"
    id="quote-submit-btn"
    class="w-full bg-brand-orange hover:bg-orange-800 text-white font-bold py-3 px-3 sm:py-4 sm:px-4 text-xs sm:text-sm uppercase tracking-wider flex items-center justify-center gap-1.5 transition-colors mt-6 shadow-md rounded-none focus-ring disabled:opacity-70 disabled:cursor-not-allowed"
  >
    <span class="sm:hidden">Get Quote →</span>
    <span class="hidden sm:inline">Check Availability & Get Quote →</span>
  </button>

  <p class="text-xs text-neutral-400 mt-4">
    By submitting you agree to be contacted about your project. We do not share your information.
  </p>

  <div class="mt-8 flex items-center justify-center gap-2">
    <span class="flex items-center gap-0.5 text-brand-orange text-sm" aria-hidden="true">★ ★ ★ ★ ★</span>
    <span class="text-[10px] font-bold text-neutral-400 uppercase tracking-wider">4.9, 125 Google Reviews</span>
  </div>

  <p id="form-message" class="hidden text-sm mt-2" role="status" aria-live="polite"></p>
</form>

<div
  id="quote-success-panel"
  class="hidden mt-6 border border-neutral-700 bg-neutral-900/80 px-4 py-4 rounded-none"
>
  <p class="text-xs font-semibold uppercase tracking-[0.18em] text-neutral-400 mb-3">
    Your Customer Success Manager
  </p>
  <div class="flex items-center gap-4">
    <picture class="shrink-0">
      <source srcset="/jackie.avif" type="image/avif" />
      <img
        src="/jackie.png"
        alt="Jackie Slagle, Customer Success Manager at DeckMasters"
        class="w-14 h-14 rounded-md object-cover border border-neutral-700 bg-neutral-800"
        loading="lazy"
      />
    </picture>
    <div>
      <p class="font-semibold text-sm text-neutral-50">Jackie Slagle</p>
      <p class="text-xs text-neutral-400">Customer Success Manager</p>
      <p class="mt-1 text-xs text-neutral-300">
        <span class="font-medium">Phone:</span> (907) 891-8283
      </p>
      <p class="text-xs text-neutral-300">
        <span class="font-medium">Email:</span> meeting@deckmastersak.com
      </p>
    </div>
  </div>
  <div class="mt-4 flex flex-col sm:flex-row sm:flex-nowrap gap-2 sm:gap-3">
    <a
      href="sms:+19078918283"
      class="inline-flex items-center justify-center px-3 py-2 text-[11px] font-semibold uppercase tracking-[0.16em] bg-brand-orange text-white hover:bg-orange-800 rounded-none focus-ring"
      aria-label="Text Jackie"
    >
      Text
    </a>
    <a
      href="tel:+19078918283"
      class="inline-flex items-center justify-center px-3 py-2 text-[11px] font-semibold uppercase tracking-[0.16em] border border-neutral-600 text-neutral-100 hover:bg-neutral-800 rounded-none focus-ring"
      aria-label="Call Jackie"
    >
      Call
    </a>
    <a
      href="mailto:meeting@deckmastersak.com"
      class="inline-flex items-center justify-center px-3 py-2 text-[11px] font-semibold uppercase tracking-[0.16em] border border-neutral-600 text-neutral-100 hover:bg-neutral-800 rounded-none focus-ring"
      aria-label="Email Jackie"
    >
      Email
    </a>
  </div>
  <button
    id="quote-reset-btn"
    type="button"
    class="mt-4 text-[11px] text-neutral-400 underline underline-offset-2 hover:text-neutral-200"
  >
    Submit another request
  </button>
</div>

<script>
  const form = document.getElementById('quote-form') as HTMLFormElement | null;
  const submitBtn = document.getElementById('quote-submit-btn') as HTMLButtonElement | null;
  const messageEl = document.getElementById('form-message') as HTMLParagraphElement | null;
  const successPanel = document.getElementById('quote-success-panel') as HTMLDivElement | null;
  const resetBtn = document.getElementById('quote-reset-btn') as HTMLButtonElement | null;

  if (form && messageEl) {
    const formEl = form as HTMLFormElement;

    function showMessage(text: string, isError: boolean) {
      if (!messageEl) return;
      messageEl.textContent = text;
      messageEl.classList.remove('hidden', 'text-brand-orange', 'text-red-600');
      messageEl.classList.add(isError ? 'text-red-600' : 'text-brand-orange');
      if (successPanel) {
        if (isError) {
          successPanel.classList.add('hidden');
          formEl.classList.remove('hidden');
        } else {
          successPanel.classList.remove('hidden');
          formEl.classList.add('hidden');
        }
      }
    }

    formEl.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!messageEl) return;
      if (submitBtn) submitBtn.disabled = true;
      messageEl.classList.add('hidden');
      if (successPanel) successPanel.classList.add('hidden');

      const getValue = (selector: string) => {
        const field = formEl.querySelector(selector) as
          | HTMLInputElement
          | HTMLTextAreaElement
          | HTMLSelectElement
          | null;
        return field?.value?.trim() || '';
      };

      const payload = {
        name: getValue('[name="name"]'),
        email: getValue('[name="email"]'),
        phone: getValue('[name="phone"]'),
        serviceType: getValue('[name="serviceType"]'),
        projectDescription: getValue('[name="projectDescription"]'),
      };

      try {
        const res = await fetch('/api/submit-quote', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        const data = await res.json().catch(() => ({}));
        if (res.ok && data.success) {
          showMessage(
            data.message || "Thank you! You're all set — meet your customer success manager below.",
            false
          );
          formEl.reset();
        } else {
          showMessage(data.error || 'Something went wrong. Please try again or call us.', true);
        }
      } catch {
        showMessage('Network error. Please try again or call us.', true);
      } finally {
        if (submitBtn) submitBtn.disabled = false;
      }
    });

    if (resetBtn && successPanel) {
      resetBtn.addEventListener('click', () => {
        successPanel.classList.add('hidden');
        formEl.classList.remove('hidden');
        messageEl.classList.add('hidden');
        formEl.reset();
      });
    }
  }
</script>

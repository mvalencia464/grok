---
/**
 * Quote form — submits to Cloudflare Pages Function /api/submit-quote, which creates a GHL contact.
 */
import siteData from '../data/site.json';

// Build flat list of selected service names from all categories for dropdown
const serviceOptions = siteData.categories.flatMap((cat: { services: { name: string; selected: boolean }[] }) =>
  cat.services.filter((s: { selected: boolean }) => s.selected).map((s: { name: string }) => s.name)
);
const neighborhoods = siteData.neighborhoods as string[];
---

<form
  id="quote-form"
  class="space-y-6 rounded-2xl border border-neutral-200 bg-surface-elevated p-8"
  aria-label="Request a quote"
>
  <h2 class="text-xl font-semibold text-neutral-800">Request a Quote</h2>
  <p class="text-sm text-neutral-600">
    Fill out the form below and we'll get back to you with a free estimate.
  </p>

  <div class="grid gap-6 sm:grid-cols-2">
    <label class="block">
      <span class="block text-sm font-medium text-neutral-700">Name</span>
      <input
        type="text"
        name="name"
        required
        autocomplete="name"
        class="mt-1 block w-full rounded-lg border border-neutral-300 bg-white px-3 py-2 text-neutral-800 shadow-sm focus:border-accent focus:ring-1 focus:ring-accent"
      />
    </label>
    <label class="block">
      <span class="block text-sm font-medium text-neutral-700">Phone</span>
      <input
        type="tel"
        name="phone"
        required
        autocomplete="tel"
        class="mt-1 block w-full rounded-lg border border-neutral-300 bg-white px-3 py-2 text-neutral-800 shadow-sm focus:border-accent focus:ring-1 focus:ring-accent"
      />
    </label>
  </div>

  <label class="block">
    <span class="block text-sm font-medium text-neutral-700">Email</span>
    <input
      type="email"
      name="email"
      required
      autocomplete="email"
      class="mt-1 block w-full rounded-lg border border-neutral-300 bg-white px-3 py-2 text-neutral-800 shadow-sm focus:border-accent focus:ring-1 focus:ring-accent"
    />
  </label>

  <label class="block">
    <span class="block text-sm font-medium text-neutral-700">Service type</span>
    <select
      name="serviceType"
      required
      class="mt-1 block w-full rounded-lg border border-neutral-300 bg-white px-3 py-2 text-neutral-800 shadow-sm focus:border-accent focus:ring-1 focus:ring-accent"
    >
      <option value="">Select a service</option>
      {serviceOptions.map((name) => (
        <option value={name}>{name}</option>
      ))}
    </select>
  </label>

  <label class="block">
    <span class="block text-sm font-medium text-neutral-700">Project description</span>
    <textarea
      name="projectDescription"
      rows={4}
      required
      class="mt-1 block w-full rounded-lg border border-neutral-300 bg-white px-3 py-2 text-neutral-800 shadow-sm focus:border-accent focus:ring-1 focus:ring-accent"
    />
  </label>

  <label class="block">
    <span class="block text-sm font-medium text-neutral-700">Address / neighborhood (optional)</span>
    <select
      name="neighborhood"
      class="mt-1 block w-full rounded-lg border border-neutral-300 bg-white px-3 py-2 text-neutral-800 shadow-sm focus:border-accent focus:ring-1 focus:ring-accent"
    >
      <option value="">Select if applicable</option>
      {neighborhoods.map((n) => (
        <option value={n}>{n}</option>
      ))}
    </select>
  </label>

  <button
    type="submit"
    id="quote-submit-btn"
    class="w-full rounded-lg bg-accent px-4 py-3 text-base font-medium text-white transition-colors duration-200 hover:bg-accent-dark focus-ring disabled:opacity-70 disabled:cursor-not-allowed"
  >
    Submit request
  </button>

  <p class="text-xs text-neutral-500">
    By submitting you agree to be contacted about your project. We do not share your information.
  </p>
  <p id="form-message" class="hidden text-sm mt-2" role="status" aria-live="polite"></p>
</form>

<script>
  const form = document.getElementById('quote-form');
  const submitBtn = document.getElementById('quote-submit-btn');
  const messageEl = document.getElementById('form-message');
  if (!form || !messageEl) return;

  function showMessage(text, isError) {
    messageEl.textContent = text;
    messageEl.classList.remove('hidden', 'text-accent-dark', 'text-red-600');
    messageEl.classList.add(isError ? 'text-red-600' : 'text-accent-dark');
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (submitBtn) submitBtn.disabled = true;
    messageEl.classList.add('hidden');

    const payload = {
      name: form.querySelector('[name="name"]')?.value?.trim() || '',
      email: form.querySelector('[name="email"]')?.value?.trim() || '',
      phone: form.querySelector('[name="phone"]')?.value?.trim() || '',
      serviceType: form.querySelector('[name="serviceType"]')?.value?.trim() || '',
      projectDescription: form.querySelector('[name="projectDescription"]')?.value?.trim() || '',
      neighborhood: form.querySelector('[name="neighborhood"]')?.value?.trim() || '',
    };

    try {
      const res = await fetch('/api/submit-quote', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      const data = await res.json().catch(() => ({}));
      if (res.ok && data.success) {
        showMessage(data.message || 'Thank you! We\'ll be in touch soon.', false);
        form.reset();
      } else {
        showMessage(data.error || 'Something went wrong. Please try again or call us.', true);
      }
    } catch {
      showMessage('Network error. Please try again or call us.', true);
    } finally {
      if (submitBtn) submitBtn.disabled = false;
    }
  });
</script>

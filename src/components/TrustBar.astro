---
const site = (await import('../data/site.json')).default;
const city = site.primaryCity;
const items = [
  { icon: '★', label: `#1 Rated in ${city}` },
  { icon: '🛡️', label: '25 Year Structural Warranty' },
  { icon: '🔨', label: 'Master Craftsmen Certified' },
];
---

<section class="bg-neutral-50 border-t border-neutral-200 py-6" aria-label="Trust badges">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <ul class="flex flex-wrap justify-between items-center gap-6 text-[10px] font-bold uppercase tracking-[0.15em] text-neutral-500">
      {items.map(({ icon, label }) => (
        <li class="flex items-center gap-2">
          <span class="text-brand-orange" aria-hidden="true">{icon}</span>
          {label}
        </li>
      ))}
    </ul>
  </div>
</section>

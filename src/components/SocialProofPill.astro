---
/**
 * Social Proof Pill: overlapping avatar stack + original Google badge (logo, stars, 4.9, 125 reviews).
 * Data from google-reviews.json (7 named reviewers). Links to #reviews. Uses astro:assets 32×32 for Lighthouse.
 */
import type { ImageMetadata } from 'astro';
import { getImage } from 'astro:assets';

const PILL_AUTHORS = [
  'Jana Weltzin',
  'Tim Bowman',
  'Joseph Leman',
  'Andrew Neuerburg',
  'Trenton Millar',
  'Beth Wilson',
  'carrie harris',
];

const data = (await import('../data/google-reviews.json')).default;
const rawReviews = data?.rawReviews ?? [];
const byAuthor = (name: string) =>
  rawReviews.find((r: { author: string }) => r.author === name);
const pillReviews = PILL_AUTHORS.map(byAuthor).filter(Boolean);

const avatarGlob = import.meta.glob<{ default: ImageMetadata }>('../assets/avatars/*.{jpg,jpeg,png,webp}');

const resolveAvatar = async (filename: string): Promise<string | undefined> => {
  if (!filename) return undefined;
  const key = Object.keys(avatarGlob).find((k) => k.endsWith(filename));
  if (!key || typeof avatarGlob[key] !== 'function') return undefined;
  const mod = await (avatarGlob[key] as () => Promise<{ default: ImageMetadata }>)();
  const img = await getImage({ src: mod.default, width: 32, height: 32, format: 'avif' });
  return img.src;
};

const avatarUrls = await Promise.all(
  pillReviews.map((r) => (r?.avatarUrl ? resolveAvatar(r.avatarUrl) : Promise.resolve(undefined)))
);
---

<a
  href="#reviews"
  class="inline-flex flex-col items-start gap-2 rounded-none bg-white/95 border border-neutral-200/90 shadow-sm px-4 py-3 hover:shadow-md hover:border-neutral-300/90 transition-all duration-200 w-fit focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-orange focus-visible:ring-offset-2"
  aria-label="4.9 stars and 125+ reviews on Google — see reviews"
>
  <div class="flex -space-x-2" aria-hidden="true">
    {avatarUrls.map((src) =>
      src ? (
        <img
          src={src}
          alt=""
          width="32"
          height="32"
          class="w-8 h-8 rounded-full border-2 border-white object-cover shrink-0"
          loading="eager"
          fetchpriority="high"
        />
      ) : null
    )}
  </div>
  <div class="flex items-center gap-2 sm:gap-2.5 text-neutral-700">
    <img src="https://www.gstatic.com/images/branding/googlelogo/svg/googlelogo_clr_74x24px.svg" alt="Google" width="74" height="24" class="h-4 sm:h-5 w-auto" loading="lazy" />
    <span class="flex items-center gap-0.5 text-amber-500 text-xs sm:text-sm" aria-hidden="true">★★★★★</span>
    <span class="text-[11px] sm:text-xs font-semibold text-neutral-700 tracking-wide">4.9</span>
    <span class="text-neutral-400" aria-hidden="true">·</span>
    <span class="text-[11px] sm:text-xs font-medium text-neutral-600">125 Google Reviews</span>
  </div>
</a>
